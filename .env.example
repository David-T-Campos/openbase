# OpenBase environment configuration
#
# Copy this file to `.env` at the repo root and replace the placeholder values.
# Required variables are marked as REQUIRED.
# Optional variables are marked as OPTIONAL.

# Server
# REQUIRED: Port exposed by the OpenBase API.
PORT=3001

# REQUIRED: Runtime mode for the API (`development`, `production`, or `test`).
NODE_ENV=development

# Authentication and signing
# REQUIRED: Secret used for JWTs, API keys, and platform auth tokens.
JWT_SECRET=replace-with-a-random-secret-at-least-16-characters-long

# REQUIRED: Secret used to sign storage URLs and storage-related tokens.
STORAGE_SECRET=replace-with-a-second-random-secret-at-least-16-characters-long

# Redis
# REQUIRED: Redis connection string.
# Use `redis://localhost:6379` for local Redis, or `rediss://...` for remote Redis such as Upstash.
REDIS_URL=redis://localhost:6379

# Email
# OPTIONAL: Resend API key used for magic link delivery.
# Leave unset if you do not need email-based magic links.
RESEND_API_KEY=

# SQLite
# REQUIRED: Directory where OpenBase stores local SQLite index files.
SQLITE_BASE_PATH=./data/indexes

# Telegram API credentials
# REQUIRED unless MOCK_TELEGRAM=true.
# Create these at https://my.telegram.org
TELEGRAM_API_ID=12345678

# REQUIRED unless MOCK_TELEGRAM=true.
TELEGRAM_API_HASH=replace-with-your-telegram-api-hash

# Dashboard and redirects
# REQUIRED: Public dashboard URL used for redirects and auth flows.
DASHBOARD_URL=http://localhost:3000

# Encryption
# REQUIRED: 64-character hex key used to encrypt Telegram session strings and other secrets.
# Example generation command: `openssl rand -hex 32`
MASTER_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Development helpers
# OPTIONAL: Set to `true` to use the in-memory mock Telegram provider instead of a real Telegram session.
MOCK_TELEGRAM=false

# OPTIONAL: Set to `true` to skip the 7-day warmup and mark new projects active immediately.
# This is only allowed when NODE_ENV=development.
SKIP_WARMUP=false
