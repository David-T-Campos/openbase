{
    "name": "openbase-js",
    "version": "0.1.0",
    "description": "OpenBase JavaScript/TypeScript client SDK — mirrors the Supabase JS API",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
        "clean": "rimraf dist",
        "dev": "tsc --watch"
    },
    "dependencies": {
        "cross-fetch": "^4.0.0",
        "socket.io-client": "^4.8.1"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "rimraf": "^5.0.0",
        "typescript": "^5.4.0"
    },
    "keywords": [
        "openbase",
        "baas",
        "sdk",
        "supabase-alternative"
    ],
    "license": "MIT",
    "files": [
        "dist"
    ]
}
